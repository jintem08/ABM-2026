    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"# we kijken nu ook naar wat een buur doet. als een buur recyecelt zal je eigen recycel waarde 0.1 srijgen, maar het kan ook -0.1 gaan als de buur dus juist niet recycelt\\n\",\n",
    "    \"#nieuwste versie\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"        self.recyclewaarde = 0\\n\",\n",
    "    \"        self.sociale_gevoeligheid = 0\\n\",\n",
    "    \"        self.recyclegedrag = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.opleidingsniveau = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.inkomen = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.geslacht = random.choice([\\\"man\\\", \\\"vrouw\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Basis textielafval 12 kg/persoon/jaar\\n\",\n",
    "    \"        self.textielafval_per_week = 0.23 * 2.10  # kg/huishouden/week\\n\",\n",
    "    \"        self.textielafval_per_tijdstap = self.textielafval_per_week * 4\\n\",\n",
    "    \"        self.opgespaard_textielafval = 0\\n\",\n",
    "    \"        self.weggooifrequentie = 20  # in weken\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv inkomen\\n\",\n",
    "    \"        if self.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.8\\n\",\n",
    "    \"        elif self.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.2\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv geslacht\\n\",\n",
    "    \"        if self.geslacht == \\\"man\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.9\\n\",\n",
    "    \"        elif self.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: textielcontainer\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.capaciteit = 1250          # in kg (5 m³ * 250 kg/m³)\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"        self.ledigingsfrequentie = 8    # 1 keer per 8 weken\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def ledigen(self):\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model: stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=90, people_per_container=10):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"        self.drempel = 0.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # aantal containers berekenen\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # check of alles op het grid past\\n\",\n",
    "    \"        totaal_agents = num_people + num_containers\\n\",\n",
    "    \"        totaal_cellen = width * height\\n\",\n",
    "    \"        if totaal_agents > totaal_cellen:\\n\",\n",
    "    \"            raise ValueError(\\n\",\n",
    "    \"                f\\\"Te veel agents voor het grid: {totaal_agents} agents voor {totaal_cellen} cellen.\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # alle gehele coördinaten op het grid\\n\",\n",
    "    \"        beschikbare_posities = [(x, y) for x in range(width) for y in range(height)]\\n\",\n",
    "    \"        random.shuffle(beschikbare_posities)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers plaatsen\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            pos = beschikbare_posities.pop()\\n\",\n",
    "    \"            self.grid.place_agent(c, pos)\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens plaatsen\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            pos = beschikbare_posities.pop()\\n\",\n",
    "    \"            self.grid.place_agent(h, pos)\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # eerste berekening\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Manhattan-afstand op het grid\\n\",\n",
    "    \"    def manhattan_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return abs(pos1[0] - pos2[0]) + abs(pos1[1] - pos2[1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # dichtstbijzijnde container\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.manhattan_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # buurinvloed berekenen:\\n\",\n",
    "    \"    # +0.1 voor buur die recycelt\\n\",\n",
    "    \"    # -0.1 voor buur die niet recycelt\\n\",\n",
    "    \"    def bereken_buurinvloed(self, huishouden):\\n\",\n",
    "    \"        x, y = huishouden.pos\\n\",\n",
    "    \"        aantal_buren = 0\\n\",\n",
    "    \"        buurinvloed = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buur_posities = [\\n\",\n",
    "    \"            (x - 1, y),  # links\\n\",\n",
    "    \"            (x + 1, y),  # rechts\\n\",\n",
    "    \"            (x, y - 1),  # onder\\n\",\n",
    "    \"            (x, y + 1)   # boven\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for bx, by in buur_posities:\\n\",\n",
    "    \"            if 0 <= bx < self.grid.width and 0 <= by < self.grid.height:\\n\",\n",
    "    \"                inhoud = self.grid.get_cell_list_contents([(bx, by)])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for agent in inhoud:\\n\",\n",
    "    \"                    if isinstance(agent, Huishouden):\\n\",\n",
    "    \"                        aantal_buren += 1\\n\",\n",
    "    \"                        if agent.recyclegedrag:\\n\",\n",
    "    \"                            buurinvloed += 0.1\\n\",\n",
    "    \"                        else:\\n\",\n",
    "    \"                            buurinvloed -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return aantal_buren, buurinvloed\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # recyclegedrag bepalen\\n\",\n",
    "    \"    def bereken_recyclegedrag(self):\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            # random startwaarde\\n\",\n",
    "    \"            huishouden.recyclewaarde = random.random()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # buurinvloed\\n\",\n",
    "    \"            aantal_buren, buurinvloed = self.bereken_buurinvloed(huishouden)\\n\",\n",
    "    \"            huishouden.sociale_gevoeligheid = aantal_buren\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # afstand tot dichtstbijzijnde container\\n\",\n",
    "    \"            container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"            huishouden.afstand = afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # als huishouden direct naast een container woont -> altijd recyclen\\n\",\n",
    "    \"            if afstand == 1:\\n\",\n",
    "    \"                huishouden.recyclewaarde = self.drempel + 1\\n\",\n",
    "    \"                huishouden.recyclegedrag = True\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed buren\\n\",\n",
    "    \"            huishouden.recyclewaarde += buurinvloed\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed afstand\\n\",\n",
    "    \"            huishouden.recyclewaarde -= afstand * 0.025\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed inkomen\\n\",\n",
    "    \"            if huishouden.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.1\\n\",\n",
    "    \"            elif huishouden.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed geslacht\\n\",\n",
    "    \"            if huishouden.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.05\\n\",\n",
    "    \"            elif huishouden.geslacht == \\\"man\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.05\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # beslissing\\n\",\n",
    "    \"            huishouden.recyclegedrag = huishouden.recyclewaarde > self.drempel\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # simulatiestap\\n\",\n",
    "    \"    def stap(self):\\n\",\n",
    "    \"        self.week += 4\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens produceren textielafval\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            huishouden.opgespaard_textielafval += huishouden.textielafval_per_tijdstap\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # recyclegedrag opnieuw berekenen\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # textiel weggooien elke 20 weken\\n\",\n",
    "    \"        if self.week % 20 == 0:\\n\",\n",
    "    \"            for huishouden in self.huishoudens:\\n\",\n",
    "    \"                if huishouden.recyclegedrag:\\n\",\n",
    "    \"                    container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if container.vulgraad + huishouden.opgespaard_textielafval <= container.capaciteit:\\n\",\n",
    "    \"                        container.vulgraad += huishouden.opgespaard_textielafval\\n\",\n",
    "    \"                    else:\\n\",\n",
    "    \"                        container.vulgraad = container.capaciteit\\n\",\n",
    "    \"\\n\",\n",
    "    \"                huishouden.opgespaard_textielafval = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers legen elke 8 weken\\n\",\n",
    "    \"        if self.week % 8 == 0:\\n\",\n",
    "    \"            for container in self.containers:\\n\",\n",
    "    \"                container.ledigen()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # resultaten weergeven\\n\",\n",
    "    \"    def resultaten(self):\\n\",\n",
    "    \"        print(\\\"\\\\nRESULTATEN:\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"{'Huishouden':<12} {'Positie':<12} {'Buren':<6} {'Opleiding':<10} {'Inkomen':<10} {'Geslacht':<10} {'Afstand':<10} {'Opgespaard':<12} {'Recyclewaarde':<16} {'Recyclegedrag':<10}\\\")\\n\",\n",
    "    \"        print(\\\"-\\\" * 130)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, huishouden in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            print(\\n\",\n",
    "    \"                f\\\"H{i:<11} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.pos):<12} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.sociale_gevoeligheid:<6} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opleidingsniveau:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.inkomen:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.geslacht:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.afstand:<10.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opgespaard_textielafval:<12.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.recyclewaarde:<16.2f} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.recyclegedrag):<10}\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # visualisatie\\n\",\n",
    "    \"    def visualiseer(self):\\n\",\n",
    "    \"        plt.figure(figsize=(7, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"            kleur = \\\"blue\\\" if h.recyclegedrag else \\\"red\\\"\\n\",\n",
    "    \"            plt.scatter(x, y, color=kleur, s=60)\\n\",\n",
    "    \"            plt.text(x, y, f\\\"H{i}\\\", fontsize=5, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"green\\\", s=100, marker=\\\"s\\\")\\n\",\n",
    "    \"            plt.text(x, y, f\\\"C{i}\\\", fontsize=6, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.title(\\\"Stad met huishoudens en textielcontainers\\\")\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.xticks(range(self.grid.width))\\n\",\n",
    "    \"        plt.yticks(range(self.grid.height))\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=90, people_per_container=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# simulatie\\n\",\n",
    "    \"for week in range(4):\\n\",\n",
    "    \"    print(f\\\"\\\\nWEEK {week + 1}\\\")\\n\",\n",
    "    \"    model.stap()\\n\",\n",
    "    \"    model.visualiseer()\\n\",\n",
    "    \"    model.resultaten()\"\n",
    "   ],\n",
    "   \"id\": \"504ca470a68dcad9\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from matplotlib.animation import FuncAnimation\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model aanmaken\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=90, people_per_container=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# één figuur en as maken\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(7, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"def update(frame):\\n\",\n",
    "    \"    ax.clear()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 1 stap vooruit in de tijd\\n\",\n",
    "    \"    model.stap()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # huishoudens tekenen\\n\",\n",
    "    \"    for i, h in enumerate(model.huishoudens, start=1):\\n\",\n",
    "    \"        x, y = h.pos\\n\",\n",
    "    \"        kleur = \\\"blue\\\" if h.recyclegedrag else \\\"red\\\"\\n\",\n",
    "    \"        ax.scatter(x, y, color=kleur, s=60)\\n\",\n",
    "    \"        ax.text(x, y, f\\\"H{i}\\\", fontsize=5, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # containers tekenen\\n\",\n",
    "    \"    for i, c in enumerate(model.containers, start=1):\\n\",\n",
    "    \"        x, y = c.pos\\n\",\n",
    "    \"        ax.scatter(x, y, color=\\\"green\\\", s=100, marker=\\\"s\\\")\\n\",\n",
    "    \"        ax.text(x, y, f\\\"C{i}\\\", fontsize=6, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # opmaak\\n\",\n",
    "    \"    ax.set_title(f\\\"Stad met huishoudens en textielcontainers – week {model.week}\\\")\\n\",\n",
    "    \"    ax.set_xlim(-0.5, model.grid.width - 0.5)\\n\",\n",
    "    \"    ax.set_ylim(-0.5, model.grid.height - 0.5)\\n\",\n",
    "    \"    ax.set_xticks(range(model.grid.width))\\n\",\n",
    "    \"    ax.set_yticks(range(model.grid.height))\\n\",\n",
    "    \"    ax.grid(True)\\n\",\n",
    "    \"    ax.set_aspect(\\\"equal\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# animatie maken: 20 frames = 20 tijdstappen\\n\",\n",
    "    \"anim = FuncAnimation(fig, update, frames=20, interval=800, repeat=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
    "   \"id\": \"2f5c94b1a72dab2c\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from matplotlib.animation import FuncAnimation\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"        self.recyclewaarde = 0\\n\",\n",
    "    \"        self.sociale_gevoeligheid = 0\\n\",\n",
    "    \"        self.recyclegedrag = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.opleidingsniveau = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.inkomen = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.geslacht = random.choice([\\\"man\\\", \\\"vrouw\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Basis textielafval 12 kg/persoon/jaar\\n\",\n",
    "    \"        self.textielafval_per_week = 0.23 * 2.10  # kg/huishouden/week\\n\",\n",
    "    \"        self.textielafval_per_tijdstap = self.textielafval_per_week * 4\\n\",\n",
    "    \"        self.opgespaard_textielafval = 0\\n\",\n",
    "    \"        self.weggooifrequentie = 20  # in weken\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv inkomen\\n\",\n",
    "    \"        if self.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.8\\n\",\n",
    "    \"        elif self.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.2\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv geslacht\\n\",\n",
    "    \"        if self.geslacht == \\\"man\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.9\\n\",\n",
    "    \"        elif self.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: textielcontainer\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.capaciteit = 1250          # in kg (5 m³ * 250 kg/m³)\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"        self.ledigingsfrequentie = 8    # 1 keer per 8 weken\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def ledigen(self):\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model: stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=90, people_per_container=10):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"        self.drempel = 0.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # aantal containers berekenen\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # check of alles op het grid past\\n\",\n",
    "    \"        totaal_agents = num_people + num_containers\\n\",\n",
    "    \"        totaal_cellen = width * height\\n\",\n",
    "    \"        if totaal_agents > totaal_cellen:\\n\",\n",
    "    \"            raise ValueError(\\n\",\n",
    "    \"                f\\\"Te veel agents voor het grid: {totaal_agents} agents voor {totaal_cellen} cellen.\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # alle gehele coördinaten op het grid\\n\",\n",
    "    \"        beschikbare_posities = [(x, y) for x in range(width) for y in range(height)]\\n\",\n",
    "    \"        random.shuffle(beschikbare_posities)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers plaatsen\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            pos = beschikbare_posities.pop()\\n\",\n",
    "    \"            self.grid.place_agent(c, pos)\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens plaatsen\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            pos = beschikbare_posities.pop()\\n\",\n",
    "    \"            self.grid.place_agent(h, pos)\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # eerste berekening\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Manhattan-afstand op het grid\\n\",\n",
    "    \"    def manhattan_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return abs(pos1[0] - pos2[0]) + abs(pos1[1] - pos2[1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # dichtstbijzijnde container\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.manhattan_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # buurinvloed berekenen:\\n\",\n",
    "    \"    # +0.1 voor buur die recycelt\\n\",\n",
    "    \"    # -0.1 voor buur die niet recycelt\\n\",\n",
    "    \"    def bereken_buurinvloed(self, huishouden):\\n\",\n",
    "    \"        x, y = huishouden.pos\\n\",\n",
    "    \"        aantal_buren = 0\\n\",\n",
    "    \"        buurinvloed = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buur_posities = [\\n\",\n",
    "    \"            (x - 1, y),  # links\\n\",\n",
    "    \"            (x + 1, y),  # rechts\\n\",\n",
    "    \"            (x, y - 1),  # onder\\n\",\n",
    "    \"            (x, y + 1)   # boven\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for bx, by in buur_posities:\\n\",\n",
    "    \"            if 0 <= bx < self.grid.width and 0 <= by < self.grid.height:\\n\",\n",
    "    \"                inhoud = self.grid.get_cell_list_contents([(bx, by)])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for agent in inhoud:\\n\",\n",
    "    \"                    if isinstance(agent, Huishouden):\\n\",\n",
    "    \"                        aantal_buren += 1\\n\",\n",
    "    \"                        if agent.recyclegedrag:\\n\",\n",
    "    \"                            buurinvloed += 0.1\\n\",\n",
    "    \"                        else:\\n\",\n",
    "    \"                            buurinvloed -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return aantal_buren, buurinvloed\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # recyclegedrag bepalen\\n\",\n",
    "    \"    def bereken_recyclegedrag(self):\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            # random startwaarde\\n\",\n",
    "    \"            huishouden.recyclewaarde = random.random()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # buurinvloed\\n\",\n",
    "    \"            aantal_buren, buurinvloed = self.bereken_buurinvloed(huishouden)\\n\",\n",
    "    \"            huishouden.sociale_gevoeligheid = aantal_buren\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # afstand tot dichtstbijzijnde container\\n\",\n",
    "    \"            container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"            huishouden.afstand = afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # als huishouden direct naast een container woont -> altijd recyclen\\n\",\n",
    "    \"            if afstand == 1:\\n\",\n",
    "    \"                huishouden.recyclewaarde = self.drempel + 1\\n\",\n",
    "    \"                huishouden.recyclegedrag = True\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed buren\\n\",\n",
    "    \"            huishouden.recyclewaarde += buurinvloed\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed afstand\\n\",\n",
    "    \"            huishouden.recyclewaarde -= afstand * 0.025\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed inkomen\\n\",\n",
    "    \"            if huishouden.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.1\\n\",\n",
    "    \"            elif huishouden.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed geslacht\\n\",\n",
    "    \"            if huishouden.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.05\\n\",\n",
    "    \"            elif huishouden.geslacht == \\\"man\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.05\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # beslissing\\n\",\n",
    "    \"            huishouden.recyclegedrag = huishouden.recyclewaarde > self.drempel\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # simulatiestap\\n\",\n",
    "    \"    def stap(self):\\n\",\n",
    "    \"        self.week += 4\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens produceren textielafval\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            huishouden.opgespaard_textielafval += huishouden.textielafval_per_tijdstap\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # recyclegedrag opnieuw berekenen\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # textiel weggooien elke 20 weken\\n\",\n",
    "    \"        if self.week % 20 == 0:\\n\",\n",
    "    \"            for huishouden in self.huishoudens:\\n\",\n",
    "    \"                if huishouden.recyclegedrag:\\n\",\n",
    "    \"                    container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if container.vulgraad + huishouden.opgespaard_textielafval <= container.capaciteit:\\n\",\n",
    "    \"                        container.vulgraad += huishouden.opgespaard_textielafval\\n\",\n",
    "    \"                    else:\\n\",\n",
    "    \"                        container.vulgraad = container.capaciteit\\n\",\n",
    "    \"\\n\",\n",
    "    \"                huishouden.opgespaard_textielafval = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers legen elke 8 weken\\n\",\n",
    "    \"        if self.week % 8 == 0:\\n\",\n",
    "    \"            for container in self.containers:\\n\",\n",
    "    \"                container.ledigen()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # resultaten weergeven\\n\",\n",
    "    \"    def resultaten(self):\\n\",\n",
    "    \"        print(\\\"\\\\nRESULTATEN:\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"{'Huishouden':<12} {'Positie':<12} {'Buren':<6} {'Opleiding':<10} {'Inkomen':<10} {'Geslacht':<10} {'Afstand':<10} {'Opgespaard':<12} {'Recyclewaarde':<16} {'Recyclegedrag':<10}\\\")\\n\",\n",
    "    \"        print(\\\"-\\\" * 130)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, huishouden in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            print(\\n\",\n",
    "    \"                f\\\"H{i:<11} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.pos):<12} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.sociale_gevoeligheid:<6} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opleidingsniveau:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.inkomen:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.geslacht:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.afstand:<10.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opgespaard_textielafval:<12.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.recyclewaarde:<16.2f} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.recyclegedrag):<10}\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # visualisatie\\n\",\n",
    "    \"    def visualiseer(self, ax):\\n\",\n",
    "    \"        ax.clear()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"            kleur = \\\"blue\\\" if h.recyclegedrag else \\\"red\\\"\\n\",\n",
    "    \"            ax.scatter(x, y, color=kleur, s=60)\\n\",\n",
    "    \"            ax.text(x, y, f\\\"H{i}\\\", fontsize=5, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            ax.scatter(x, y, color=\\\"green\\\", s=100, marker=\\\"s\\\")\\n\",\n",
    "    \"            ax.text(x, y, f\\\"C{i}\\\", fontsize=6, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ax.grid()\\n\",\n",
    "    \"        ax.set_title(f\\\"Stad met huishoudens en textielcontainers - week {self.week}\\\")\\n\",\n",
    "    \"        ax.set_xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        ax.set_ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        ax.set_xticks(range(self.grid.width))\\n\",\n",
    "    \"        ax.set_yticks(range(self.grid.height))\\n\",\n",
    "    \"        ax.set_aspect(\\\"equal\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=90, people_per_container=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# figuur maken\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(7, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# updatefunctie voor animatie\\n\",\n",
    "    \"def update(frame):\\n\",\n",
    "    \"    print(f\\\"\\\\nWEEK {frame + 1}\\\")\\n\",\n",
    "    \"    model.stap()\\n\",\n",
    "    \"    model.visualiseer(ax)\\n\",\n",
    "    \"    model.resultaten()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# animatie\\n\",\n",
    "    \"anim = FuncAnimation(fig, update, frames=4, interval=800, repeat=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\"\n",
    "   ],\n",
    "   \"id\": \"944afdbab67d848b\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from matplotlib.animation import FuncAnimation\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"        self.recyclewaarde = 0\\n\",\n",
    "    \"        self.sociale_gevoeligheid = 0\\n\",\n",
    "    \"        self.recyclegedrag = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.opleidingsniveau = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.inkomen = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.geslacht = random.choice([\\\"man\\\", \\\"vrouw\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.textielafval_per_week = 0.23 * 2.10\\n\",\n",
    "    \"        self.textielafval_per_tijdstap = self.textielafval_per_week * 4\\n\",\n",
    "    \"        self.opgespaard_textielafval = 0\\n\",\n",
    "    \"        self.weggooifrequentie = 20\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.8\\n\",\n",
    "    \"        elif self.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.2\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.geslacht == \\\"man\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.9\\n\",\n",
    "    \"        elif self.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"        self.capaciteit = 1250\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"        self.ledigingsfrequentie = 8\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def ledigen(self):\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=90, people_per_container=10):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"        self.drempel = 0.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        totaal_agents = num_people + num_containers\\n\",\n",
    "    \"        totaal_cellen = width * height\\n\",\n",
    "    \"        if totaal_agents > totaal_cellen:\\n\",\n",
    "    \"            raise ValueError(\\n\",\n",
    "    \"                f\\\"Te veel agents voor het grid: {totaal_agents} agents voor {totaal_cellen} cellen.\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        beschikbare_posities = [(x, y) for x in range(width) for y in range(height)]\\n\",\n",
    "    \"        random.shuffle(beschikbare_posities)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            pos = beschikbare_posities.pop()\\n\",\n",
    "    \"            self.grid.place_agent(c, pos)\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            pos = beschikbare_posities.pop()\\n\",\n",
    "    \"            self.grid.place_agent(h, pos)\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def manhattan_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return abs(pos1[0] - pos2[0]) + abs(pos1[1] - pos2[1])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.manhattan_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def bereken_buurinvloed(self, huishouden):\\n\",\n",
    "    \"        x, y = huishouden.pos\\n\",\n",
    "    \"        aantal_buren = 0\\n\",\n",
    "    \"        buurinvloed = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buur_posities = [\\n\",\n",
    "    \"            (x - 1, y),\\n\",\n",
    "    \"            (x + 1, y),\\n\",\n",
    "    \"            (x, y - 1),\\n\",\n",
    "    \"            (x, y + 1)\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for bx, by in buur_posities:\\n\",\n",
    "    \"            if 0 <= bx < self.grid.width and 0 <= by < self.grid.height:\\n\",\n",
    "    \"                inhoud = self.grid.get_cell_list_contents([(bx, by)])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for agent in inhoud:\\n\",\n",
    "    \"                    if isinstance(agent, Huishouden):\\n\",\n",
    "    \"                        aantal_buren += 1\\n\",\n",
    "    \"                        if agent.recyclegedrag:\\n\",\n",
    "    \"                            buurinvloed += 0.1\\n\",\n",
    "    \"                        else:\\n\",\n",
    "    \"                            buurinvloed -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return aantal_buren, buurinvloed\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def bereken_recyclegedrag(self):\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            huishouden.recyclewaarde = random.random()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            aantal_buren, buurinvloed = self.bereken_buurinvloed(huishouden)\\n\",\n",
    "    \"            huishouden.sociale_gevoeligheid = aantal_buren\\n\",\n",
    "    \"\\n\",\n",
    "    \"            container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"            huishouden.afstand = afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if afstand == 1:\\n\",\n",
    "    \"                huishouden.recyclewaarde = self.drempel + 1\\n\",\n",
    "    \"                huishouden.recyclegedrag = True\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            huishouden.recyclewaarde += buurinvloed\\n\",\n",
    "    \"            huishouden.recyclewaarde -= afstand * 0.025\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if huishouden.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.1\\n\",\n",
    "    \"            elif huishouden.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if huishouden.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.05\\n\",\n",
    "    \"            elif huishouden.geslacht == \\\"man\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.05\\n\",\n",
    "    \"\\n\",\n",
    "    \"            huishouden.recyclegedrag = huishouden.recyclewaarde > self.drempel\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def stap(self):\\n\",\n",
    "    \"        self.week += 4\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            huishouden.opgespaard_textielafval += huishouden.textielafval_per_tijdstap\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.week % 20 == 0:\\n\",\n",
    "    \"            for huishouden in self.huishoudens:\\n\",\n",
    "    \"                if huishouden.recyclegedrag:\\n\",\n",
    "    \"                    container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if container.vulgraad + huishouden.opgespaard_textielafval <= container.capaciteit:\\n\",\n",
    "    \"                        container.vulgraad += huishouden.opgespaard_textielafval\\n\",\n",
    "    \"                    else:\\n\",\n",
    "    \"                        container.vulgraad = container.capaciteit\\n\",\n",
    "    \"\\n\",\n",
    "    \"                huishouden.opgespaard_textielafval = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.week % 8 == 0:\\n\",\n",
    "    \"            for container in self.containers:\\n\",\n",
    "    \"                container.ledigen()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def visualiseer(self, ax):\\n\",\n",
    "    \"        ax.clear()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"            kleur = \\\"blue\\\" if h.recyclegedrag else \\\"red\\\"\\n\",\n",
    "    \"            grootte = 90 if h.recyclegedrag else 40\\n\",\n",
    "    \"            ax.scatter(x, y, s=grootte, color=kleur)\\n\",\n",
    "    \"            ax.text(x, y, f\\\"H{i}\\\", fontsize=5, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            ax.scatter(x, y, s=120, color=\\\"green\\\", marker=\\\"s\\\")\\n\",\n",
    "    \"            ax.text(x, y, f\\\"C{i}\\\", fontsize=6, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        aantal_recyclers = sum(h.recyclegedrag for h in self.huishoudens)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ax.set_title(f\\\"Week {self.week} | Recyclers: {aantal_recyclers}/{len(self.huishoudens)}\\\")\\n\",\n",
    "    \"        ax.set_xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        ax.set_ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        ax.set_xticks(range(self.grid.width))\\n\",\n",
    "    \"        ax.set_yticks(range(self.grid.height))\\n\",\n",
    "    \"        ax.grid(True)\\n\",\n",
    "    \"        ax.set_aspect(\\\"equal\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=90, people_per_container=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(7, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"model.visualiseer(ax)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def update(frame):\\n\",\n",
    "    \"    model.stap()\\n\",\n",
    "    \"    model.visualiseer(ax)\\n\",\n",
    "    \"\\n\",\n",
    "    \"anim = FuncAnimation(\\n\",\n",
    "    \"    fig,\\n\",\n",
    "    \"    update,\\n\",\n",
    "    \"    frames=20,\\n\",\n",
    "    \"    interval=1000,\\n\",\n",
    "    \"    repeat=False,\\n\",\n",
    "    \"    cache_frame_data=False\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"from IPython.display import HTML\\n\",\n",
    "    \"HTML(anim.to_jshtml())\\n\",\n",
    "    \"\\n\",\n",
    "    \"#nieuweste poging\\n\",\n",
    "    \"\\n\"\n",
    "   ],\n",

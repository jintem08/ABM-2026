    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model runnen\\n\",\n",
    "    \"model = Stad(width=100, height=100, num_people=50, people_per_container=10)\\n\",\n",
    "    \"model.visualiseer()\\n\",\n",
    "    \"model.resultaten()\"\n",
    "   ],\n",
    "   \"id\": \"6a95a57d548d9b75\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"## laatste versie (versie 4)\\n\",\n",
    "    \"# eigenschappen textielcontainer toegevoegd: capaciteit, vulgraad, ledigingfrequentie\\n\",\n",
    "    \"# stap functie toegevoegd (maar klopt nog niet helemaal)\\n\",\n",
    "    \"# later nog toevoegen: textiel uberhaupt wel of niet weggooien (hoe vaak gooi je textiel weg?)\\n\",\n",
    "    \"# later juiste waardes gebruiken voor invloed van bepaalde eigenschappen + juiste verhoudingen man/vrouw, inkomens, opleiding, aantal inwoners, aantal containers, etc.\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"        self.recyclewaarde = 0\\n\",\n",
    "    \"        self.sociale_gevoeligheid = 0\\n\",\n",
    "    \"        self.recyclegedrag = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.opleidingsniveau = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.inkomen = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.geslacht = random.choice([\\\"man\\\", \\\"vrouw\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Basis textielafval 12 kg/persoon/jaar\\n\",\n",
    "    \"        self.textielafval = 12\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv. inkomen\\n\",\n",
    "    \"        if self.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"            self.textielafval *= 0.8  #Lager inkomen, minder textielafval\\n\",\n",
    "    \"        elif self.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"            self.textielafval *= 1.2  #Hoger inkomen, meer textielafval\\n\",\n",
    "    \"        #\\\"midden\\\" inkomen hoeft geen aanpassing, dus blijft 12 kg/persoon/jaar\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv. geslacht\\n\",\n",
    "    \"        if self.geslacht == \\\"man\\\":\\n\",\n",
    "    \"            self.textielafval *= 0.9  # Mannen hebben minder textielafval\\n\",\n",
    "    \"        elif self.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"            self.textielafval *= 1.1  # Vrouwen hebben meer textielafval\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: textielcontainer\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.capaciteit = 1250          # in kg (5 m³ * 250 kg/m³)\\n\",\n",
    "    \"        self.vulgraad = 0               # Hoe vol is de container?\\n\",\n",
    "    \"        self.ledigingsfrequentie = 8    # Lediging 1 keer per 8 weken\\n\",\n",
    "    \"        self.week = 0                   # Huidige week in de simulatie\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Container ledigen (reset de vulgraad naar 0)\\n\",\n",
    "    \"    def ledigen(self):\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model: stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=5, people_per_container=2):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # drempelwaarde\\n\",\n",
    "    \"        self.drempel = 0.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # aantal containers berekenen\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers plaatsen\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(c, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens plaatsen\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(h, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # recyclegedrag berekenen\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # afstand berekenen\\n\",\n",
    "    \"    def euclidische_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return math.sqrt((pos1[0] - pos2[0]) ** 2 + (pos1[1] - pos2[1]) ** 2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # dichtstbijzijnde container\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.euclidische_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # buren tellen (4 richtingen)\\n\",\n",
    "    \"    def tel_buren(self, huishouden):\\n\",\n",
    "    \"        x, y = huishouden.pos\\n\",\n",
    "    \"        aantal_buren = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buur_posities = [\\n\",\n",
    "    \"            (x - 1, y),\\n\",\n",
    "    \"            (x + 1, y),\\n\",\n",
    "    \"            (x, y - 1),\\n\",\n",
    "    \"            (x, y + 1)\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for bx, by in buur_posities:\\n\",\n",
    "    \"            if 0 <= bx < self.grid.width and 0 <= by < self.grid.height:\\n\",\n",
    "    \"                inhoud = self.grid.get_cell_list_contents([(bx, by)])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for agent in inhoud:\\n\",\n",
    "    \"                    if isinstance(agent, Huishouden):\\n\",\n",
    "    \"                        aantal_buren += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return aantal_buren\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # recyclegedrag bepalen\\n\",\n",
    "    \"    def bereken_recyclegedrag(self):\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            # random startwaarde\\n\",\n",
    "    \"            huishouden.recyclewaarde = random.random()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # buren tellen\\n\",\n",
    "    \"            huishouden.sociale_gevoeligheid = self.tel_buren(huishouden)\\n\",\n",
    "    \"            #afstand tot textielcontainer\\n\",\n",
    "    \"            container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"            huishouden.afstand = afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # +0.1 per buur\\n\",\n",
    "    \"            huishouden.recyclewaarde += huishouden.sociale_gevoeligheid * 0.05\\n\",\n",
    "    \"            # -0.1 per afstandseenheid tot textielcontainer\\n\",\n",
    "    \"            huishouden.recyclewaarde -= afstand * 0.025\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed inkomen op recyclewaarde (hoger inkomen -> meer milieubewust)\\n\",\n",
    "    \"            if huishouden.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.1\\n\",\n",
    "    \"            elif huishouden.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed geslacht op recyclewaarde (vrouwen meer milieubewust dan mannen)\\n\",\n",
    "    \"            if huishouden.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.05\\n\",\n",
    "    \"            elif huishouden.geslacht == \\\"man\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.05\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # beslissing\\n\",\n",
    "    \"            huishouden.recyclegedrag = huishouden.recyclewaarde > self.drempel\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Huishouden recyclet het textielafval -> textielafval toevoegen aan vulgraad van de container\\n\",\n",
    "    \"            if huishouden.recyclegedrag:\\n\",\n",
    "    \"                # Geen overvolle container\\n\",\n",
    "    \"                if container.vulgraad + huishouden.textielafval <= container.capaciteit:\\n\",\n",
    "    \"                    container.vulgraad += huishouden.textielafval\\n\",\n",
    "    \"                else:\\n\",\n",
    "    \"                    # Als de container vol is, voeg alleen zo veel mogelijk textielafval toe en het resterende textielafval gaat bij het restafval\\n\",\n",
    "    \"                    container.vulgraad = container.capaciteit\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Simulatie van de tijd (om de containers te legen na elke week)\\n\",\n",
    "    \"    def stap(self):\\n\",\n",
    "    \"        # Simuleer het recyclegedrag van huishoudens\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Update weeknummer in de simulatie\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            container.week += 4  # Elke stap is 4 weken\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Als het aantal weken een veelvoud van 8 is, leeg de container\\n\",\n",
    "    \"        if container.week % 8 == 0:\\n\",\n",
    "    \"            container.ledigen()  # Ledig de container\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # resultaten weergeven in nette tabel\\n\",\n",
    "    \"    def resultaten(self):\\n\",\n",
    "    \"        print(\\\"\\\\nRESULTATEN:\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"{'Huishouden':<12} {'Positie':<12} {'Buren':<6} {'Opleiding':<10} {'Inkomen':<10} {'Geslacht':<10} {'Afstand':<10} {'Textielafval':<12} {'Recyclewaarde':<16} {'Recyclegedrag':<10}\\\")\\n\",\n",
    "    \"        print(\\\"-\\\" * 120)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, huishouden in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            print(\\n\",\n",
    "    \"                f\\\"H{i:<11} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.pos):<12} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.sociale_gevoeligheid:<6} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opleidingsniveau:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.inkomen:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.geslacht:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.afstand:<10.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.textielafval:<12.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.recyclewaarde:<16.2f} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.recyclegedrag):<10}\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # visualisatie: stad met inwoners en textielcontainers\\n\",\n",
    "    \"    def visualiseer(self):\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"            kleur = \\\"blue\\\" if h.recyclegedrag else \\\"red\\\"\\n\",\n",
    "    \"            plt.scatter(x, y, color=kleur, s=60)\\n\",\n",
    "    \"            plt.text(x, y, f\\\"H{i}\\\", fontsize=5, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"green\\\", s=100, marker=\\\"s\\\")\\n\",\n",
    "    \"            plt.text(x, y, f\\\"C{i}\\\", fontsize=6, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.title(\\\"Stad met huishoudens en textielcontainers\\\")\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model\\n\",\n",
    "    \"model = Stad(width=100, height=100, num_people=100, people_per_container=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Simuleer 10 weken (4 stappen)\\n\",\n",
    "    \"for week in range(4):\\n\",\n",
    "    \"    print(f\\\"\\\\nWEEK {week + 1}\\\")\\n\",\n",
    "    \"    model.stap()\\n\",\n",
    "    \"    model.visualiseer()\\n\",\n",
    "    \"    model.resultaten()\"\n",
    "   ],\n",
    "   \"id\": \"720d59c7087587d0\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"## laatste versie (versie 5)\\n\",\n",
    "    \"# toegevoegd: huishoudens gooien textiel 1 keer per 20 weken weg, in de tussentijd sparen ze hun textiel op thuis\\n\",\n",
    "    \"# later juiste waardes gebruiken voor invloed van bepaalde eigenschappen + juiste verhoudingen man/vrouw, inkomens, opleiding, aantal inwoners, aantal containers, etc.\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"        self.recyclewaarde = 0\\n\",\n",
    "    \"        self.sociale_gevoeligheid = 0\\n\",\n",
    "    \"        self.recyclegedrag = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.opleidingsniveau = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.inkomen = random.choice([\\\"laag\\\", \\\"midden\\\", \\\"hoog\\\"])\\n\",\n",
    "    \"        self.geslacht = random.choice([\\\"man\\\", \\\"vrouw\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Basis textielafval 12 kg/persoon/jaar\\n\",\n",
    "    \"        self.textielafval_per_week = 0.23 * 2.10  # kg/huishouden/week\\n\",\n",
    "    \"        self.textielafval_per_tijdstap = self.textielafval_per_week * 4\\n\",\n",
    "    \"        self.opgespaard_textielafval = 0\\n\",\n",
    "    \"        self.weggooifrequentie = 20  # in weken\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv. inkomen\\n\",\n",
    "    \"        if self.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.8  #Lager inkomen, minder textielafval\\n\",\n",
    "    \"        elif self.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.2  #Hoger inkomen, meer textielafval\\n\",\n",
    "    \"        #\\\"midden\\\" inkomen hoeft geen aanpassing, dus blijft 12 kg/persoon/jaar\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Correctie hoeveelheid textielafval obv. geslacht\\n\",\n",
    "    \"        if self.geslacht == \\\"man\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 0.9  # Mannen hebben minder textielafval\\n\",\n",
    "    \"        elif self.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"            self.textielafval_per_tijdstap *= 1.1  # Vrouwen hebben meer textielafval\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: textielcontainer\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.capaciteit = 1250          # in kg (5 m³ * 250 kg/m³)\\n\",\n",
    "    \"        self.vulgraad = 0               # Hoe vol is de container?\\n\",\n",
    "    \"        self.ledigingsfrequentie = 8    # Lediging 1 keer per 8 weken\\n\",\n",
    "    \"        self.week = 0                   # Huidige week in de simulatie\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Container ledigen (reset de vulgraad naar 0)\\n\",\n",
    "    \"    def ledigen(self):\\n\",\n",
    "    \"        self.vulgraad = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model: stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=5, people_per_container=2):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"        self.week = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # drempelwaarde\\n\",\n",
    "    \"        self.drempel = 0.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # aantal containers berekenen\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers plaatsen\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(c, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens plaatsen\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(h, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # recyclegedrag berekenen\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # afstand berekenen\\n\",\n",
    "    \"    def euclidische_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return math.sqrt((pos1[0] - pos2[0]) ** 2 + (pos1[1] - pos2[1]) ** 2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # dichtstbijzijnde container\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.euclidische_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # buren tellen (4 richtingen)\\n\",\n",
    "    \"    def tel_buren(self, huishouden):\\n\",\n",
    "    \"        x, y = huishouden.pos\\n\",\n",
    "    \"        aantal_buren = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buur_posities = [\\n\",\n",
    "    \"            (x - 1, y),\\n\",\n",
    "    \"            (x + 1, y),\\n\",\n",
    "    \"            (x, y - 1),\\n\",\n",
    "    \"            (x, y + 1)\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for bx, by in buur_posities:\\n\",\n",
    "    \"            if 0 <= bx < self.grid.width and 0 <= by < self.grid.height:\\n\",\n",
    "    \"                inhoud = self.grid.get_cell_list_contents([(bx, by)])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for agent in inhoud:\\n\",\n",
    "    \"                    if isinstance(agent, Huishouden):\\n\",\n",
    "    \"                        aantal_buren += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return aantal_buren\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # recyclegedrag bepalen\\n\",\n",
    "    \"    def bereken_recyclegedrag(self):\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            # random startwaarde\\n\",\n",
    "    \"            huishouden.recyclewaarde = random.random()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # buren tellen\\n\",\n",
    "    \"            huishouden.sociale_gevoeligheid = self.tel_buren(huishouden)\\n\",\n",
    "    \"            #afstand tot textielcontainer\\n\",\n",
    "    \"            container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"            huishouden.afstand = afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # +0.1 per buur\\n\",\n",
    "    \"            huishouden.recyclewaarde += huishouden.sociale_gevoeligheid * 0.05\\n\",\n",
    "    \"            # -0.1 per afstandseenheid tot textielcontainer\\n\",\n",
    "    \"            huishouden.recyclewaarde -= afstand * 0.025\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed inkomen op recyclewaarde (hoger inkomen -> meer milieubewust)\\n\",\n",
    "    \"            if huishouden.inkomen == \\\"hoog\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.1\\n\",\n",
    "    \"            elif huishouden.inkomen == \\\"laag\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # invloed geslacht op recyclewaarde (vrouwen meer milieubewust dan mannen)\\n\",\n",
    "    \"            if huishouden.geslacht == \\\"vrouw\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde += 0.05\\n\",\n",
    "    \"            elif huishouden.geslacht == \\\"man\\\":\\n\",\n",
    "    \"                huishouden.recyclewaarde -= 0.05\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # beslissing\\n\",\n",
    "    \"            huishouden.recyclegedrag = huishouden.recyclewaarde > self.drempel\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Simulatie van de tijd (om de containers te legen na elke week)\\n\",\n",
    "    \"    def stap(self):\\n\",\n",
    "    \"        self.week += 4 #weken\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens produceren textielafval en sparen dat op\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            huishouden.opgespaard_textielafval += huishouden.textielafval_per_tijdstap\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # recyclegedrag opnieuw berekenen\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens gooien gemiddeld 1 keer per 20 weken textiel weg\\n\",\n",
    "    \"        if self.week % 20 == 0:\\n\",\n",
    "    \"            for huishouden in self.huishoudens:\\n\",\n",
    "    \"                if huishouden.recyclegedrag:\\n\",\n",
    "    \"                    container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if container.vulgraad + huishouden.opgespaard_textielafval <= container.capaciteit:\\n\",\n",
    "    \"                        container.vulgraad += huishouden.opgespaard_textielafval\\n\",\n",
    "    \"                    else:\\n\",\n",
    "    \"                        container.vulgraad = container.capaciteit\\n\",\n",
    "    \"\\n\",\n",
    "    \"                # na weggooimoment is de voorraad thuis weg\\n\",\n",
    "    \"                huishouden.opgespaard_textielafval = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers worden 1 keer per 8 weken geleegd\\n\",\n",
    "    \"        if self.week % 8 == 0:\\n\",\n",
    "    \"            for container in self.containers:\\n\",\n",
    "    \"                container.ledigen()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # resultaten weergeven in nette tabel\\n\",\n",
    "    \"    def resultaten(self):\\n\",\n",
    "    \"        print(\\\"\\\\nRESULTATEN:\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"{'Huishouden':<12} {'Positie':<12} {'Buren':<6} {'Opleiding':<10} {'Inkomen':<10} {'Geslacht':<10} {'Afstand':<10} {'Opgespaard':<12} {'Recyclewaarde':<16} {'Recyclegedrag':<10}\\\")\\n\",\n",
    "    \"        print(\\\"-\\\" * 120)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, huishouden in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            print(\\n\",\n",
    "    \"                f\\\"H{i:<11} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.pos):<12} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.sociale_gevoeligheid:<6} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opleidingsniveau:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.inkomen:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.geslacht:<10} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.afstand:<10.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.opgespaard_textielafval:<12.2f} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.recyclewaarde:<16.2f} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.recyclegedrag):<10}\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # visualisatie: stad met inwoners en textielcontainers\\n\",\n",
    "    \"    def visualiseer(self):\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"            kleur = \\\"blue\\\" if h.recyclegedrag else \\\"red\\\"\\n\",\n",
    "    \"            plt.scatter(x, y, color=kleur, s=60)\\n\",\n",
    "    \"            plt.text(x, y, f\\\"H{i}\\\", fontsize=5, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"green\\\", s=100, marker=\\\"s\\\")\\n\",\n",
    "    \"            plt.text(x, y, f\\\"C{i}\\\", fontsize=6, ha=\\\"center\\\", va=\\\"center\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.title(\\\"Stad met huishoudens en textielcontainers\\\")\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model\\n\",\n",
    "    \"model = Stad(width=100, height=100, num_people=100, people_per_container=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Simuleer 10 weken (4 stappen)\\n\",\n",
    "    \"for week in range(4):\\n\",\n",
    "    \"    print(f\\\"\\\\nWEEK {week + 1}\\\")\\n\",\n",
    "    \"    model.stap()\\n\",\n",
    "    \"    model.visualiseer()\\n\",\n",
    "    \"    model.resultaten()\"\n",
    "   ],\n",

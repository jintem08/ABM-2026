    "   \"source\": [\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Dit is de eerste agent: huishoudens\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Dit is de tweede agent: containers\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Hierin simuleren we de stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=5, people_per_container=10):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Grid waarin meerdere agents op dezelfde plek kunnen staan\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Lijsten voor huishoudens en containers\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Teller voor unieke ids\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Bereken aantal containers\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Plaats de containers in het grid\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(c, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Plaats de huishoudens in het grid\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(h, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Geeft elke agent een uniek id\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Bereken de Euclidische afstand tussen twee posities\\n\",\n",
    "    \"    def euclidische_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return math.sqrt((pos1[0] - pos2[0])**2 + (pos1[1] - pos2[1])**2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Toon voor elk huishouden de afstand tot de container\\n\",\n",
    "    \"    def toon_afstanden(self):\\n\",\n",
    "    \"        container = self.containers[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"Container staat op positie: {container.pos}\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"            afstand = self.euclidische_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"            print(f\\\"Huishouden {huishouden.unique_id} staat op {huishouden.pos} --> afstand = {afstand:.2f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Laat het grid zien\\n\",\n",
    "    \"    def show(self):\\n\",\n",
    "    \"        for h in self.huishoudens:\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Teken huishouden\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"red\\\", s=40)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Label met unique_id\\n\",\n",
    "    \"            plt.text(x, y, str(h.unique_id), fontsize=8, ha=\\\"center\\\", va=\\\"bottom\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for c in self.containers:\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Teken container\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"green\\\", s=120, marker=\\\"s\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Label voor container\\n\",\n",
    "    \"            plt.text(x, y, \\\"C\\\", fontsize=10, ha=\\\"center\\\", va=\\\"center\\\", color=\\\"white\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model maken en tonen\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=5, people_per_container=10)\\n\",\n",
    "    \"model.show()\\n\",\n",
    "    \"model.toon_afstanden()\"\n",
    "   ],\n",
    "   \"id\": \"a59eb278504e4fa0\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: container\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model: stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=5, people_per_container=2):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # bereken aantal containers\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # plaats containers\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(c, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # plaats huishoudens\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(h, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # maak steeds een nieuw uniek id\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # bereken euclidische afstand tussen twee posities\\n\",\n",
    "    \"    def euclidische_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return math.sqrt((pos1[0] - pos2[0])**2 + (pos1[1] - pos2[1])**2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # zoek voor een huishouden welke container het dichtstbij is\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.euclidische_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            #dit omdat huishoudens altijd naar containers zullen lopen die het meest dichtbij zijn (aanname)\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # print per huishouden de dichtstbijzijnde container en de afstand\\n\",\n",
    "    \"    def toon_resultaten(self):\\n\",\n",
    "    \"        print(\\\"Containers:\\\")\\n\",\n",
    "    \"        for i, container in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            print(f\\\"Container {i} staat op positie {container.pos}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(\\\"\\\\nHuishoudens:\\\")\\n\",\n",
    "    \"        for i, huishouden in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            container, afstand = self.dichtstbijzijnde_container(huishouden)\\n\",\n",
    "    \"            container_nummer = self.containers.index(container) + 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            print(\\n\",\n",
    "    \"                f\\\"Huishouden {i} staat op {huishouden.pos} \\\"\\n\",\n",
    "    \"                f\\\"--> gaat naar container {container_nummer} op {container.pos} \\\"\\n\",\n",
    "    \"                f\\\"--> afstand = {afstand:.2f}\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # laat het grid zien\\n\",\n",
    "    \"    def show(self):\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"red\\\", s=40)\\n\",\n",
    "    \"            plt.text(x, y, f\\\"H{i}\\\", fontsize=8, ha=\\\"center\\\", va=\\\"bottom\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"green\\\", s=120, marker=\\\"s\\\")\\n\",\n",
    "    \"            plt.text(x, y, f\\\"C{i}\\\", fontsize=8, ha=\\\"center\\\", va=\\\"center\\\", color=\\\"white\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model maken\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=5, people_per_container=2)\\n\",\n",
    "    \"model.show()\\n\",\n",
    "    \"model.toon_resultaten()\"\n",
    "   ],\n",
    "   \"id\": \"513e7c903de7b739\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"# ik wil nu meenemen dat huishoudens buren kunnen hebben, voor het gemak rechts, links onder en boven. al deze buren geven een beinvloedingswaarde van +1. deze beinvloedingswaarde koppelt terug naar recyclegedrag. Ik denk dat recycle gedrag een random getal word tussen 0-1 en dat dan dus deze beinvloedingswaarde erbij komt. wanneer recycle gedrag boven een bepaald getal komt gaat een huishouden recycelen en anders niet. Voor nu neem ik aan dat elke buur zorgt voor +0.1 aan recyclegedarg erbij komt. dus 4 buren is +0.4\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: huishouden\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.recyclewaarde = 0\\n\",\n",
    "    \"        self.sociale_gevoeligheid = 0\\n\",\n",
    "    \"        self.recyclet = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Agent: container\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, unique_id, model):\\n\",\n",
    "    \"        super().__init__(unique_id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Model: stad\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=5, people_per_container=2):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # drempelwaarde\\n\",\n",
    "    \"        self.drempel = 0.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # aantal containers berekenen\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # containers plaatsen\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(c, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # huishoudens plaatsen\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(h, (random.randint(0, width - 1), random.randint(0, height - 1)))\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # recyclegedrag berekenen\\n\",\n",
    "    \"        self.bereken_recyclegedrag()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # uniek id\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # afstand berekenen\\n\",\n",
    "    \"    def euclidische_afstand(self, pos1, pos2):\\n\",\n",
    "    \"        return math.sqrt((pos1[0] - pos2[0])**2 + (pos1[1] - pos2[1])**2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # dichtstbijzijnde container\\n\",\n",
    "    \"    def dichtstbijzijnde_container(self, huishouden):\\n\",\n",
    "    \"        beste_container = None\\n\",\n",
    "    \"        kleinste_afstand = float(\\\"inf\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for container in self.containers:\\n\",\n",
    "    \"            afstand = self.euclidische_afstand(huishouden.pos, container.pos)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if afstand < kleinste_afstand:\\n\",\n",
    "    \"                kleinste_afstand = afstand\\n\",\n",
    "    \"                beste_container = container\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return beste_container, kleinste_afstand\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # buren tellen (4 richtingen)\\n\",\n",
    "    \"    def tel_buren(self, huishouden):\\n\",\n",
    "    \"        x, y = huishouden.pos\\n\",\n",
    "    \"        aantal_buren = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        buur_posities = [\\n\",\n",
    "    \"            (x - 1, y),\\n\",\n",
    "    \"            (x + 1, y),\\n\",\n",
    "    \"            (x, y - 1),\\n\",\n",
    "    \"            (x, y + 1)\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for bx, by in buur_posities:\\n\",\n",
    "    \"            if 0 <= bx < self.grid.width and 0 <= by < self.grid.height:\\n\",\n",
    "    \"                inhoud = self.grid.get_cell_list_contents([(bx, by)])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for agent in inhoud:\\n\",\n",
    "    \"                    if isinstance(agent, Huishouden):\\n\",\n",
    "    \"                        aantal_buren += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return aantal_buren\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # recyclegedrag bepalen\\n\",\n",
    "    \"    def bereken_recyclegedrag(self):\\n\",\n",
    "    \"        for huishouden in self.huishoudens:\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # random startwaarde\\n\",\n",
    "    \"            huishouden.recyclewaarde = random.random()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # buren tellen\\n\",\n",
    "    \"            huishouden.sociale_gevoeligheid = self.tel_buren(huishouden)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # +0.1 per buur\\n\",\n",
    "    \"            huishouden.recyclewaarde += huishouden.sociale_gevoeligheid * 0.1\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # beslissing\\n\",\n",
    "    \"            if huishouden.recyclewaarde > self.drempel:\\n\",\n",
    "    \"                huishouden.recyclet = True\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                huishouden.recyclet = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # nette tabel\\n\",\n",
    "    \"    def toon_resultaten(self):\\n\",\n",
    "    \"        print(\\\"\\\\nRESULTATEN:\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"{'Huishouden':<12} {'Positie':<12} {'Buren':<6} {'Recyclewaarde':<16} {'Recyclet':<10}\\\")\\n\",\n",
    "    \"        print(\\\"-\\\" * 60)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, huishouden in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            print(\\n\",\n",
    "    \"                f\\\"H{i:<11} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.pos):<12} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.sociale_gevoeligheid:<6} \\\"\\n\",\n",
    "    \"                f\\\"{huishouden.recyclewaarde:<16.2f} \\\"\\n\",\n",
    "    \"                f\\\"{str(huishouden.recyclet):<10}\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # visualisatie\\n\",\n",
    "    \"    def show(self):\\n\",\n",
    "    \"        for i, h in enumerate(self.huishoudens, start=1):\\n\",\n",
    "    \"            x, y = h.pos\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if h.recyclet:\\n\",\n",
    "    \"                kleur = \\\"blue\\\"\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                kleur = \\\"red\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"            plt.scatter(x, y, color=kleur, s=40)\\n\",\n",
    "    \"            plt.text(x, y, f\\\"H{i}\\\", fontsize=8, ha=\\\"center\\\", va=\\\"bottom\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i, c in enumerate(self.containers, start=1):\\n\",\n",
    "    \"            x, y = c.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=\\\"green\\\", s=120, marker=\\\"s\\\")\\n\",\n",
    "    \"            plt.text(x, y, f\\\"C{i}\\\", fontsize=8, ha=\\\"center\\\", va=\\\"center\\\", color=\\\"white\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# model runnen\\n\",\n",
    "    \"model = Stad(width=10, height=10, num_people=5, people_per_container=2)\\n\",\n",
    "    \"model.show()\\n\",\n",
    "    \"model.toon_resultaten()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"#\"\n",
    "   ],\n",

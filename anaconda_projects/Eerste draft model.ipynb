    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class Person(Agent):\\n\",\n",
    "    \"    def __init__(self, uid, model, color):\\n\",\n",
    "    \"        super().__init__(uid, model)\\n\",\n",
    "    \"        self.color = color\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class City(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_agents=None):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # dit zorgt ervoor dat een random aantal agenten op het grid terecht komt.\\n\",\n",
    "    \"        if num_agents is None:\\n\",\n",
    "    \"            num_agents = random.randint(5, 15)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.persons = []\\n\",\n",
    "    \"# alle agenten (dus husihoudens) krijgen een rode kleur op het grid\\n\",\n",
    "    \"        possible_colors = [\\\"red\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for i in range(num_agents):\\n\",\n",
    "    \"            color = random.choice(possible_colors)\\n\",\n",
    "    \"            person = Person(i, self, color)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            x = random.randint(0, width - 1)\\n\",\n",
    "    \"            y = random.randint(0, height - 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            self.grid.place_agent(person, (x, y))\\n\",\n",
    "    \"            self.persons.append(person)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def show(self):\\n\",\n",
    "    \"        plt.figure(figsize=(6, 6))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for person in self.persons:\\n\",\n",
    "    \"            x, y = person.pos\\n\",\n",
    "    \"            plt.scatter(x, y, color=person.color, s=100)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.xticks(range(self.grid.width))\\n\",\n",
    "    \"        plt.yticks(range(self.grid.height))\\n\",\n",
    "    \"        plt.grid(True)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = City()\\n\",\n",
    "    \"model.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for person in model.persons:\\n\",\n",
    "    \"    print(f\\\"Agent {person.unique_id} staat op {person.pos} en heeft kleur {person.color}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"fc82eeb76c1453fe\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"from mesa import Model, Agent\\n\",\n",
    "    \"from mesa.space import MultiGrid\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"\\n\",\n",
    "    \"#dit is de eerste agent, de huishoudens. nu staan er nog geen variabelen in, maar dat is wat we later wel gaan toevoegen.\\n\",\n",
    "    \"class Huishouden(Agent):\\n\",\n",
    "    \"    def __init__(self, id, model):\\n\",\n",
    "    \"        super().__init__(id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"#dit is de tweede agent, de containers. hier komen later ook nog meer karakteristieken bij\\n\",\n",
    "    \"class Container(Agent):\\n\",\n",
    "    \"    def __init__(self, id, model):\\n\",\n",
    "    \"        super().__init__(id, model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"#hierbinnen gaan wij simuleren, deze karakteristieken moeten ook aangepast worden\\n\",\n",
    "    \"class Stad(Model):\\n\",\n",
    "    \"    def __init__(self, width=10, height=10, num_people=100, people_per_container=250):\\n\",\n",
    "    \"        #width is de breedte, height de hoogte, num people aantal personen in de stad, people per container is de variabele die wij nog moeten beargumenteren\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.grid = MultiGrid(width, height, torus=False)\\n\",\n",
    "    \"        #multi grid houdt in dat er meerdere agents op een plek kunnen syaan, we moeten nadenken of dit wel kan met een huis? ik denk van wel omdat elk vakje een paar km is\\n\",\n",
    "    \"        #door de torus stoppen we bij de rand en gaat helemaal rechts niet door links etc\\n\",\n",
    "    \"\\n\",\n",
    "    \"        #lijst met alle huishoudens\\n\",\n",
    "    \"        self.huishoudens = []\\n\",\n",
    "    \"        #lijst met alle containers\\n\",\n",
    "    \"        self.containers = []\\n\",\n",
    "    \"        #telt alle unieke ids\\n\",\n",
    "    \"        self.id = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        #deze formule bereknt het aantal containers aan de hand van de personen. de aantal containers worden altijd afgerond naar boven toe\\n\",\n",
    "    \"        num_containers = math.ceil(num_people / people_per_container)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        #plaats de containers die berekend zijn in het grid\\n\",\n",
    "    \"        for _ in range(num_containers):\\n\",\n",
    "    \"            c = Container(self.next_id(), self)\\n\",\n",
    "    \"            #dit geeft elke container een unieke plaats binnen de stad\\n\",\n",
    "    \"            self.grid.place_agent(c, (random.randint(0, width-1), random.randint(0, height-1)))\\n\",\n",
    "    \"            #voeg hem toe aan de lijst van de containers\\n\",\n",
    "    \"            self.containers.append(c)\\n\",\n",
    "    \"\\n\",\n",
    "    \"       #plaats de huishoudens in het grid/stad\\n\",\n",
    "    \"        for _ in range(num_people):\\n\",\n",
    "    \"            h = Huishouden(self.next_id(), self)\\n\",\n",
    "    \"            self.grid.place_agent(h, (random.randint(0, width-1), random.randint(0, height-1)))\\n\",\n",
    "    \"            self.huishoudens.append(h)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    #elke keer als er een agent gemaakt word gaat het id met 1 omhoog, zo voorkom je dat agents dezelfde id krijgen\\n\",\n",
    "    \"    def next_id(self):\\n\",\n",
    "    \"        self.id += 1\\n\",\n",
    "    \"        return self.id\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def show(self):\\n\",\n",
    "    \"        for p in self.huishoudens:\\n\",\n",
    "    \"            plt.scatter(p.pos[0], p.pos[1], color=\\\"red\\\", s=20)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for c in self.containers:\\n\",\n",
    "    \"            plt.scatter(c.pos[0], c.pos[1], color=\\\"green\\\", s=100, marker=\\\"s\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        plt.grid()\\n\",\n",
    "    \"        plt.xlim(-0.5, self.grid.width - 0.5)\\n\",\n",
    "    \"        plt.ylim(-0.5, self.grid.height - 0.5)\\n\",\n",
    "    \"        plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = Stad(width=100, height=100, num_people=650, people_per_container=100)\\n\",\n",
    "    \"model.show()\"\n",
    "   ],\n",
    "   \"id\": \"6e5888bd86bc6143\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"code\",\n",
    "   \"outputs\": [],\n",
